{
  "datasets": [
    {
      "name": "articles_data",
      "displayName": "Articles Data",
      "query": "SELECT publication_year, journal, source, is_preprint, publication_type, COUNT(*) as article_count, AVG(citation_count) as avg_citations, SUM(citation_count) as total_citations FROM serverless_stable_k2zkdm_catalog.meridian_research.articles GROUP BY publication_year, journal, source, is_preprint, publication_type ORDER BY publication_year, article_count DESC"
    },
    {
      "name": "authors_data",
      "displayName": "Authors Data",
      "query": "SELECT full_name, h_index, article_count, first_pub_year, last_pub_year, last_pub_year - first_pub_year as career_span FROM serverless_stable_k2zkdm_catalog.meridian_research.authors ORDER BY h_index DESC"
    },
    {
      "name": "mesh_data",
      "displayName": "MeSH Terms",
      "query": "SELECT mesh_term, article_count FROM serverless_stable_k2zkdm_catalog.meridian_research.mesh_terms ORDER BY article_count DESC LIMIT 15"
    },
    {
      "name": "entity_data",
      "displayName": "Extracted Entities",
      "query": "SELECT entity_type, entity_value, COUNT(*) as article_count, AVG(confidence) as avg_confidence FROM serverless_stable_k2zkdm_catalog.meridian_research.article_entities GROUP BY entity_type, entity_value ORDER BY article_count DESC LIMIT 20"
    },
    {
      "name": "top_journals",
      "displayName": "Top Journals",
      "query": "SELECT journal, COUNT(*) as article_count FROM serverless_stable_k2zkdm_catalog.meridian_research.articles GROUP BY journal ORDER BY article_count DESC LIMIT 10"
    }
  ],
  "pages": [
    {
      "name": "publication-landscape",
      "displayName": "Publication Landscape",
      "pageType": "PAGE_TYPE_CANVAS",
      "layout": [
        {
          "widget": {
            "name": "pub-title",
            "multilineTextboxSpec": {
              "lines": ["## Publication Landscape"]
            }
          },
          "position": {"x": 0, "y": 0, "width": 6, "height": 1}
        },
        {
          "widget": {
            "name": "pub-subtitle",
            "multilineTextboxSpec": {
              "lines": ["Dr. Anika Park's view of Meridian's biomedical research corpus"]
            }
          },
          "position": {"x": 0, "y": 1, "width": 6, "height": 1}
        },
        {
          "widget": {
            "name": "kpi-total-articles",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "articles_data",
                "fields": [{"name": "sum(article_count)", "expression": "SUM(`article_count`)"}],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "sum(article_count)", "displayName": "Total Articles"}
              },
              "frame": {"showTitle": true, "title": "Total Articles"}
            }
          },
          "position": {"x": 0, "y": 2, "width": 2, "height": 3}
        },
        {
          "widget": {
            "name": "kpi-total-authors",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "authors_data",
                "fields": [{"name": "count(full_name)", "expression": "COUNT(`full_name`)"}],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "count(full_name)", "displayName": "Total Authors"}
              },
              "frame": {"showTitle": true, "title": "Total Authors"}
            }
          },
          "position": {"x": 2, "y": 2, "width": 2, "height": 3}
        },
        {
          "widget": {
            "name": "kpi-avg-citations",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "articles_data",
                "fields": [{"name": "avg(avg_citations)", "expression": "AVG(`avg_citations`)"}],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "avg(avg_citations)", "displayName": "Avg Citations / Article"}
              },
              "frame": {"showTitle": true, "title": "Avg Citations per Article"}
            }
          },
          "position": {"x": 4, "y": 2, "width": 2, "height": 3}
        },
        {
          "widget": {
            "name": "pubs-by-year",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "articles_data",
                "fields": [
                  {"name": "publication_year", "expression": "`publication_year`"},
                  {"name": "sum(article_count)", "expression": "SUM(`article_count`)"}
                ],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {"fieldName": "publication_year", "scale": {"type": "categorical"}, "displayName": "Year"},
                "y": {"fieldName": "sum(article_count)", "scale": {"type": "quantitative"}, "displayName": "Articles"}
              },
              "frame": {"showTitle": true, "title": "Publications by Year"}
            }
          },
          "position": {"x": 0, "y": 5, "width": 3, "height": 5}
        },
        {
          "widget": {
            "name": "top-journals-bar",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "top_journals",
                "fields": [
                  {"name": "journal", "expression": "`journal`"},
                  {"name": "article_count", "expression": "`article_count`"}
                ],
                "disaggregated": true
              }
            }],
            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {"fieldName": "article_count", "scale": {"type": "quantitative"}, "displayName": "Articles"},
                "y": {"fieldName": "journal", "scale": {"type": "categorical"}, "displayName": "Journal"}
              },
              "frame": {"showTitle": true, "title": "Top 10 Journals by Article Count"}
            }
          },
          "position": {"x": 3, "y": 5, "width": 3, "height": 5}
        },
        {
          "widget": {
            "name": "preprint-pie",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "articles_data",
                "fields": [
                  {"name": "is_preprint", "expression": "`is_preprint`"},
                  {"name": "sum(article_count)", "expression": "SUM(`article_count`)"}
                ],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 3,
              "widgetType": "pie",
              "encodings": {
                "angle": {"fieldName": "sum(article_count)", "scale": {"type": "quantitative"}, "displayName": "Articles"},
                "color": {"fieldName": "is_preprint", "scale": {"type": "categorical"}, "displayName": "Is Preprint"}
              },
              "frame": {"showTitle": true, "title": "Preprint vs Peer-Reviewed"}
            }
          },
          "position": {"x": 0, "y": 10, "width": 6, "height": 5}
        }
      ]
    },
