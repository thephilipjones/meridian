{
  "datasets": [
    {
      "name": "reg_actions_data",
      "displayName": "Regulatory Actions (SEC Tier)",
      "query": "SELECT action_year, action_type, action_source, company_name, COUNT(*) as action_count, COUNT(DISTINCT company_name) as distinct_companies FROM serverless_stable_k2zkdm_catalog.meridian_regulatory.regulatory_actions WHERE subscription_tier = 'sec_only' GROUP BY action_year, action_type, action_source, company_name ORDER BY action_count DESC"
    },
    {
      "name": "company_risk_data",
      "displayName": "Company Risk Profiles",
      "query": "SELECT company_name, risk_tier, sec_filings, fda_actions, total_actions, internal_score, latest_action_date, primary_state FROM serverless_stable_k2zkdm_catalog.meridian_regulatory.company_risk_signals ORDER BY total_actions DESC"
    },
    {
      "name": "patent_data",
      "displayName": "Patent Landscape",
      "query": "SELECT filing_year, patent_type, assignee, COUNT(*) as patent_count, AVG(grant_lag_days) as avg_grant_lag FROM serverless_stable_k2zkdm_catalog.meridian_regulatory.patent_landscape GROUP BY filing_year, patent_type, assignee ORDER BY patent_count DESC"
    },
    {
      "name": "top_assignees",
      "displayName": "Top Patent Assignees",
      "query": "SELECT assignee, COUNT(*) as patent_count FROM serverless_stable_k2zkdm_catalog.meridian_regulatory.patent_landscape GROUP BY assignee ORDER BY patent_count DESC LIMIT 10"
    }
  ],
  "pages": [
    {
      "name": "regulatory-overview",
      "displayName": "Regulatory Overview",
      "pageType": "PAGE_TYPE_CANVAS",
      "layout": [
        {
          "widget": {
            "name": "reg-title",
            "multilineTextboxSpec": {
              "lines": ["## Regulatory Overview"]
            }
          },
          "position": {"x": 0, "y": 0, "width": 6, "height": 1}
        },
        {
          "widget": {
            "name": "reg-subscription-banner",
            "multilineTextboxSpec": {
              "lines": ["**Acme Bank — SEC Tier** | Showing SEC filings data. **Upgrade to Premium** for FDA enforcement actions, patent monitoring, and cross-agency risk signals."]
            }
          },
          "position": {"x": 0, "y": 1, "width": 6, "height": 1}
        },
        {
          "widget": {
            "name": "kpi-reg-actions",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "reg_actions_data",
                "fields": [{"name": "sum(action_count)", "expression": "SUM(`action_count`)"}],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "sum(action_count)", "displayName": "SEC Actions"}
              },
              "frame": {"showTitle": true, "title": "SEC Actions (Scoped)"}
            }
          },
          "position": {"x": 0, "y": 2, "width": 2, "height": 3}
        },
        {
          "widget": {
            "name": "kpi-companies-tracked",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "reg_actions_data",
                "fields": [{"name": "countdistinct(company_name)", "expression": "COUNT(DISTINCT `company_name`)"}],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "countdistinct(company_name)", "displayName": "Companies Tracked"}
              },
              "frame": {"showTitle": true, "title": "Companies Tracked"}
            }
          },
          "position": {"x": 2, "y": 2, "width": 2, "height": 3}
        },
        {
          "widget": {
            "name": "kpi-action-types",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "reg_actions_data",
                "fields": [{"name": "countdistinct(action_type)", "expression": "COUNT(DISTINCT `action_type`)"}],
                "disaggregated": false
              }
            }],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {"fieldName": "countdistinct(action_type)", "displayName": "Action Types"}
              },
              "frame": {"showTitle": true, "title": "Action Types"}
            }
          },
          "position": {"x": 4, "y": 2, "width": 2, "height": 3}
        },
        {
          "widget": {
            "name": "actions-by-year",
            "queries": [{
              "name": "main_query",
              "query": {
                "datasetName": "reg_actions_data",
