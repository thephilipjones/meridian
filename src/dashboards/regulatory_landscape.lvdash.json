            "spec": {
              "version": 3,
              "widgetType": "bar",
              "encodings": {
                "x": {"fieldName": "action_year", "scale": {"type": "categorical"}, "displayName": "Year"},
                "y": {"fieldName": "sum(action_count)", "scale": {"type": "quantitative"}, "displayName": "Actions"},
                "color": {"fieldName": "action_type", "scale": {"type": "categorical"}, "displayName": "Type"}
              },
              "frame": {"showTitle": true, "title": "SEC Actions by Year & Type"}
            }
