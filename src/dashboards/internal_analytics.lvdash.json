{
  "datasets": [
    {
      "name": "revenue_data",
      "displayName": "Revenue Data",
      "query": "SELECT fiscal_quarter, product_line, SUM(revenue) as revenue, SUM(cost_of_data) as cost_of_data, SUM(gross_margin) as gross_margin, SUM(customer_count) as customer_count FROM serverless_stable_k2zkdm_catalog.meridian_internal.revenue_summary GROUP BY fiscal_quarter, product_line ORDER BY fiscal_quarter, revenue DESC"
    },
    {
      "name": "health_data",
      "displayName": "Customer Health",
      "query": "SELECT account_name, arr, products_subscribed, api_calls_30d, avg_response_ms_30d, error_rate_30d, health_score, health_tier FROM serverless_stable_k2zkdm_catalog.meridian_internal.customer_health ORDER BY health_score ASC"
    },
    {
      "name": "pipeline_data",
      "displayName": "Pipeline Data",
      "query": "SELECT stage, product_line, region, fiscal_quarter, deal_count, total_amount, total_arr, avg_deal_size, conversion_rate FROM serverless_stable_k2zkdm_catalog.meridian_internal.sales_pipeline ORDER BY total_amount DESC"
    },
    {
      "name": "usage_data",
      "displayName": "Product Usage",
      "query": "SELECT account_name, product as product_line, api_calls, unique_users, avg_response_ms, error_rate, bytes_served FROM serverless_stable_k2zkdm_catalog.meridian_internal.product_usage ORDER BY api_calls DESC"
    },
    {
      "name": "account_scorecard",
      "displayName": "Account Monetization",
      "query": "SELECT h.account_name, h.arr, COALESCE(u.total_api_calls, 0) as api_calls_30d, CASE WHEN COALESCE(u.total_api_calls, 0) > 0 THEN ROUND(h.arr / u.total_api_calls, 2) ELSE 0 END as revenue_per_call, h.health_tier, CASE WHEN COALESCE(u.total_api_calls, 0) < 50 THEN 'Low' WHEN COALESCE(u.total_api_calls, 0) < 150 THEN 'Medium' ELSE 'High' END as usage_level FROM serverless_stable_k2zkdm_catalog.meridian_internal.customer_health h LEFT JOIN (SELECT account_name, SUM(api_calls) as total_api_calls FROM serverless_stable_k2zkdm_catalog.meridian_internal.product_usage GROUP BY account_name) u ON h.account_name = u.account_name ORDER BY h.arr DESC"
    },
    {
      "name": "ai_insight_data",
      "displayName": "AI Executive Insight",
      "query": "SELECT ai_query('databricks-meta-llama-3-1-8b-instruct', CONCAT('Summarize these business metrics in one executive sentence highlighting the most important trend and any risk: ', 'Total revenue: $', CAST(total_rev AS STRING), ', Total customers: ', CAST(total_cust AS STRING), ', At-risk accounts: ', CAST(at_risk AS STRING), ', Critical accounts: ', CAST(critical AS STRING), ', Top product by revenue: ', top_product)) as ai_insight FROM (SELECT (SELECT ROUND(SUM(revenue), 0) FROM serverless_stable_k2zkdm_catalog.meridian_internal.revenue_summary) as total_rev, (SELECT SUM(customer_count) FROM serverless_stable_k2zkdm_catalog.meridian_internal.revenue_summary) as total_cust, (SELECT COUNT(*) FROM serverless_stable_k2zkdm_catalog.meridian_internal.customer_health WHERE health_tier = 'At Risk') as at_risk, (SELECT COUNT(*) FROM serverless_stable_k2zkdm_catalog.meridian_internal.customer_health WHERE health_tier = 'Critical') as critical, (SELECT product_line FROM serverless_stable_k2zkdm_catalog.meridian_internal.revenue_summary GROUP BY product_line ORDER BY SUM(revenue) DESC LIMIT 1) as top_product)"
    }
  ],
